package com.example.nammarailubuddy

import com.google.firebase.database.DataSnapshot
import com.google.firebase.database.DatabaseError
import com.google.firebase.database.FirebaseDatabase
import com.google.firebase.database.ValueEventListener

object FirebaseHelper {

    // FIX: Use the correct regional URL — your DB is in asia-southeast1
    private val database = FirebaseDatabase.getInstance(
        "https://nammarailbuddy-default-rtdb.asia-southeast1.firebasedatabase.app"
    )
    private val pingsRef = database.getReference("platform_pings")

    fun submitPlatformPing(ping: PlatformPing, onSuccess: () -> Unit, onError: (String) -> Unit) {
        val key = pingsRef.child(ping.stationCode).child(ping.trainNumber).push().key ?: return
        pingsRef.child(ping.stationCode).child(ping.trainNumber).child(key)
            .setValue(ping)
            .addOnSuccessListener { onSuccess() }
            .addOnFailureListener { onError(it.message ?: "Unknown error") }
    }

    fun listenForPings(
        stationCode: String,
        trainNumber: String,
        onUpdate: (List<PlatformPing>) -> Unit
    ): ValueEventListener {
        val listener = object : ValueEventListener {
            override fun onDataChange(snapshot: DataSnapshot) {
                val pings = mutableListOf<PlatformPing>()
                for (child in snapshot.children) {
                    child.getValue(PlatformPing::class.java)?.let { pings.add(it) }
                }
                val twoHoursAgo = System.currentTimeMillis() - (2 * 60 * 60 * 1000)
                onUpdate(
                    pings.filter { it.timestamp > twoHoursAgo }
                        .sortedByDescending { it.timestamp }
                )
            }
            override fun onCancelled(error: DatabaseError) {}
        }
        pingsRef.child(stationCode).child(trainNumber).addValueEventListener(listener)
        return listener
    }

    fun removePingListener(
        stationCode: String,
        trainNumber: String,
        listener: ValueEventListener
    ) {
        pingsRef.child(stationCode).child(trainNumber).removeEventListener(listener)
    }

    fun analyzePings(pings: List<PlatformPing>, originalPlatform: Int): PingAnalysis {
        if (pings.isEmpty()) return PingAnalysis(
            confirmedCount = 0,
            avgDelayMinutes = 0,
            isDelayed = false,
            communityPlatform = originalPlatform,
            platformCorrected = false
        )

        val confirmedCount = pings.size
        val delayPings = pings.filter { it.delayMinutes > 0 }
        val avgDelay = if (delayPings.isNotEmpty())
            delayPings.map { it.delayMinutes }.average().toInt() else 0
        val isDelayed = delayPings.size > (confirmedCount / 2)

        val platformVotes = pings
            .filter { it.correctedPlatform > 0 }
            .groupBy { it.correctedPlatform }
            .mapValues { it.value.size }
        val topPlatform = platformVotes.maxByOrNull { it.value }
        val communityPlatform = if (topPlatform != null && topPlatform.value >= 2)
            topPlatform.key else originalPlatform
        val platformCorrected = communityPlatform != originalPlatform

        return PingAnalysis(confirmedCount, avgDelay, isDelayed, communityPlatform, platformCorrected)
    }
}

data class PingAnalysis(
    val confirmedCount: Int,
    val avgDelayMinutes: Int,
    val isDelayed: Boolean,
    val communityPlatform: Int,
    val platformCorrected: Boolean
)